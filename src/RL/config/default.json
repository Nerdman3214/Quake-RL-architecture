{
  "project_name": "quake-rl",
  "engine": {
    "kind": "xonotic",
    "install_dir": "/media/steven/WINPE2/Xonotic",
    "client_executable": "xonotic-linux64-glx",
    "server_executable": "xonotic-linux64-dedicated",
    "base_game_dir": "data",
    "host": "127.0.0.1",
    "port": 26000
  },
  "match": {
    "mode": "deathmatch",
    "map": "boil",
    "max_players": 16,
    "bot_count": 5,
    "score_limit": 20,
    "time_limit_minutes": 10,
    "agent_name": "rlAGENT"
  },
  "environment": {
    "observation_version": "v2",
    "action_version": "v1",
    "reward_version": "v1",
    "frame_width": 160,
    "frame_height": 90,
    "frame_stack": 4,
    "action_repeat": 4
  },
  "runtime": {
    "headless_server": true,
    "launch_client": false,
    "startup_timeout_seconds": 30,
    "shutdown_timeout_seconds": 10,
    "log_dir": "src/RL/logs"
  }
}
